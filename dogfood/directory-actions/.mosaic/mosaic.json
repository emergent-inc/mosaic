{
  "actions": {
    "mosaic.newTerminal": {
      "type": "command",
      "title": "Root New Terminal",
      "subtitle": "Loaded from directory-actions/.mosaic/mosaic.json",
      "command": "echo 'ROOT NEW TERMINAL'; echo 'SOURCE=directory-actions/.mosaic/mosaic.json'; pwd",
      "target": "newTabInCurrentPane",
      "shortcut": "cmd+shift+1",
      "icon": { "type": "image", "path": "./icons/root-terminal.svg" }
    },
    "root.echo": {
      "type": "command",
      "title": "Root Echo",
      "subtitle": "Ancestor action should still merge into nested directories",
      "command": "echo 'ROOT ECHO'; echo 'SOURCE=directory-actions/.mosaic/mosaic.json'; pwd",
      "target": "newTabInCurrentPane",
      "shortcut": "cmd+shift+r",
      "icon": { "type": "emoji", "value": "🌲" }
    }
  },
  "ui": {
    "surfaceTabBar": {
      "buttons": [
        "mosaic.newTerminal",
        "root.echo",
        "mosaic.newBrowser"
      ]
    }
  }
}
