{
  "actions": {
    "mosaic.newTerminal": {
      "type": "command",
      "title": "Nested New Terminal",
      "subtitle": "Nearest .mosaic/mosaic.json should win here",
      "command": "echo 'NESTED NEW TERMINAL'; echo 'SOURCE=alpha/nested/.mosaic/mosaic.json'; pwd",
      "target": "newTabInCurrentPane",
      "shortcut": "cmd+shift+2",
      "icon": { "type": "image", "path": "./icons/nested-terminal.svg" }
    },
    "nested.echo": {
      "type": "command",
      "title": "Nested Echo",
      "subtitle": "Added by alpha/nested/.mosaic/mosaic.json",
      "command": "echo 'NESTED ECHO'; echo 'SOURCE=alpha/nested/.mosaic/mosaic.json'; pwd",
      "target": "newTabInCurrentPane",
      "shortcut": "cmd+shift+n",
      "icon": { "type": "emoji", "value": "🪺" }
    }
  },
  "ui": {
    "surfaceTabBar": {
      "buttons": [
        "mosaic.newTerminal",
        "nested.echo",
        "mosaic.splitRight"
      ]
    }
  }
}
